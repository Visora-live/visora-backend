# ─── Database ──────────────────────────────────────────
# PostgreSQL local. Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://visora_user:visora_password@localhost:5432/visora_db

# ─── App ───────────────────────────────────────────────
APP_NAME=VISORA Backend
APP_VERSION=0.1.0
ENVIRONMENT=local
API_PREFIX=/api

# Must be a JSON array (brackets required). pydantic-settings parses it as List[str].
# Example multi-origin: CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:4200"]

# ─── Camera ────────────────────────────────────────────
# "local_rtsp" while testing with IP Webcam on LAN
# "cloud_ingest" when migrating to AWS (future)
CAMERA_CONNECTION_MODE=local_rtsp

# ─── Storage ───────────────────────────────────────────
# "local" for development, "s3" for AWS (future)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage

# ─── AWS Placeholder ───────────────────────────────────
# Not implemented yet. Fill when migrating to AWS.
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
